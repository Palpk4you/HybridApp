@model HybridApp.ViewModels.RoleIndexViewModel

<h2>Roles</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All"></div>

    <div class="form-group">
        <label asp-for="NewRole.Name"></label>
        <input asp-for="NewRole.Name" class="form-control" />
        <span asp-validation-for="NewRole.Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NewRole.Description"></label>
        <input asp-for="NewRole.Description" class="form-control" />
        <span asp-validation-for="NewRole.Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
</form>

<hr />

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model.Roles)
        {
            <tr>
                <td>@role.Name</td>
                <td>@role.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@role.Id">Edit</a>
                    <form asp-action="Delete" asp-route-id="@role.Id" method="post" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Are you sure you want to delete this role?');">
                            Delete
                        </button>
                    </form>

                </td>
            </tr>
        }
    </tbody>
</table>